    <application android:icon="@mipmap/ic_launcher" android:allowBackup="false" android:label="${appName}">

        <meta-data android:name="tachiyomi.novelextension.class" android:value="${extClass}" />
        <meta-data android:name="tachiyomi.novelextension.nsfw" android:value="${nsfw}" />
        <meta-data android:name="tachiyomi.novelextension.novel" android:value="1" />

        <meta-data android:name="tachiyomix.name" android:value="${tachiyomix.name}" />
        <meta-data android:name="tachiyomix.contentWarning" android:value="${tachiyomix.contentWarning}" />
        <meta-data android:name="tachiyomix.extensionLib" android:value="${tachiyomix.extensionLib}" />

    </application>

</manifest>
